  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  travelPlan TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  @@index([travelPlanId])
  @@map("travel_plan_hotel")
}

model TravelPlanExpense {
  id           String   @id @db.VarChar(26)
  travelPlanId String   @map("travel_plan_id") @db.VarChar(26)
  category     String   @db.VarChar(64) // TICKET, HOTEL, FOOD, LOCAL_TRANSPORT, COMMUNICATION, OTHER
  expenseDate  DateTime @map("expense_date") @db.Date
  description  String   @db.VarChar(500)
  amountPaise  BigInt   @map("amount_paise")
  receiptRef   String?  @map("receipt_ref") @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  travelPlan TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  @@index([travelPlanId])
  @@map("travel_plan_expense")
}

// ==========================================================================
// Password Manager — secure credential storage
// ==========================================================================

model PasswordEntry {
  id              String  @id @db.VarChar(26)
  ownerUserId     String  @map("owner_user_id") @db.VarChar(26)
  portal          String  @db.VarChar(255) // Portal name or URL
  location        String? @db.VarChar(255) // Optional: specific page or section
  username        String  @db.VarChar(255)
  encryptedPass   String  @map("encrypted_pass") @db.Text // AES-256-GCM encrypted
  passIv          String  @map("pass_iv") @db.VarChar(32) // Initialization vector (hex)
  passTag         String  @map("pass_tag") @db.VarChar(32) // Auth tag (hex)
  notes           String? @db.Text

  // Visibility: PERSONAL = only owner, ROLE = shared with a role, ALL = everyone
  visibility      String  @default("PERSONAL") @db.VarChar(16) // PERSONAL, ROLE, ALL
  sharedRoleId    String? @map("shared_role_id") @db.VarChar(26) // FK to Role when visibility=ROLE

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  owner           User    @relation("PasswordOwner", fields: [ownerUserId], references: [id])
  sharedRole      Role?   @relation(fields: [sharedRoleId], references: [id])
  securityQuestions PasswordSecurityQuestion[]

  @@index([ownerUserId, deletedAt])
  @@index([visibility, deletedAt])
  @@index([sharedRoleId])
  @@map("password_entry")
}

model PasswordSecurityQuestion {
  id              String @id @db.VarChar(26)
  passwordEntryId String @map("password_entry_id") @db.VarChar(26)
  question        String @db.VarChar(500)
  encryptedAnswer String @map("encrypted_answer") @db.Text
  answerIv        String @map("answer_iv") @db.VarChar(32)
  answerTag       String @map("answer_tag") @db.VarChar(32)

  createdAt DateTime @default(now()) @map("created_at")

  passwordEntry PasswordEntry @relation(fields: [passwordEntryId], references: [id], onDelete: Cascade)

  @@index([passwordEntryId])
  @@map("password_security_question")
}
