model Activity {
  id            String   @id @db.VarChar(26)
  activityType  String   @map("activity_type") @db.VarChar(16) // EVENT, TASK
  subject       String   @db.VarChar(255)
  description   String?  @db.Text
  categoryCode  String   @map("category_code") @db.VarChar(64) // from lookup list "activity_category"
  userId        String   @map("user_id") @db.VarChar(26) // owner / performer

  // Event fields (null for tasks)
  startDateTime DateTime? @map("start_date_time") @db.DateTime(3)
  endDateTime   DateTime? @map("end_date_time") @db.DateTime(3)
  isAllDay      Boolean   @default(false) @map("is_all_day")

  // Task fields (null for events)
  dueDateTime   DateTime? @map("due_date_time") @db.DateTime(3)
  taskStatus    String?   @map("task_status") @db.VarChar(32) // OPEN, OVERDUE, CLOSED

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  user         User                @relation("ActivityUser", fields: [userId], references: [id])
  associations ActivityAssociation[]
  contacts     ActivityContact[]

  @@index([activityType, deletedAt])
  @@index([userId, activityType])
  @@index([startDateTime])
  @@index([dueDateTime, taskStatus])
  @@map("activity")
}

