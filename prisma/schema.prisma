// GovProjects Platform — Prisma schema
//
// Conventions (see docs/database/schema.md):
// - All IDs are ULID-like strings (26 chars) generated in app code
// - Monetary amounts stored as BigInt in paise
// - Timestamps: created_at / updated_at / deleted_at on every table
// - Every domain row carries business_unit_id where applicable
// - Soft delete by default (filter on deleted_at IS NULL)
//
// This file is a STARTING POINT. Fill in remaining entities per the module docs.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  // The default "library" Node-API engine does not support 32-bit Node builds (e.g. Win x86).
  // Switch to the "binary" engine so installs succeed on developer machines that have 32-bit Node.
  engineType      = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================================================
// Shared enums
// ==========================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// OpportunityStage and EntryPath moved to lookup lists

enum ManagedTenderStage {
  M1_INITIATE
  M2_STAKEHOLDERS
  M3_DEMO
  M4_MASTER_SI
  M5_DPR_SUBMITTED
  M6_DPR_APPROVED
  M7_RFP_PREPARED
}

enum GovernmentType {
  NATIONAL
  STATE
}

enum InfluencerType {
  POLITICAL
  BUREAUCRAT
  OTHER
}

enum InfluenceLevel {
  LOW
  MEDIUM
  HIGH
  CHAMPION
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  CONFERENCE
  GEM_PORTAL
  CPPP
  COLD_OUTREACH
  EXISTING_ACCOUNT
  OTHER
}

enum ExpenseSheetType {
  PRE_PROJECT
  DURING_PROJECT
  ADMIN_GENERAL
  REIMBURSEMENT
}

enum ExpenseSheetStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  RETURNED_FOR_CLARIFICATION
  APPROVED
  PAYMENT_PENDING
  PAID
  REJECTED
}

enum MaterialRequestStatus {
  DRAFT
  SUBMITTED
  PM_APPROVED
  BU_HEAD_APPROVED
  INDENTED
  PO_RAISED
  PARTIALLY_FULFILLED
  FULFILLED
  REJECTED
  CANCELLED
}

enum Priority {
  NORMAL
  URGENT
  EMERGENCY
}

enum TaskStatus {
  BACKLOG
  TO_DO
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  DONE
}

// ==========================================================================
// Module 1 — Organization & Business Units
// ==========================================================================

model Company {
  id            String   @id @db.VarChar(26)
  legalName     String   @map("legal_name") @db.VarChar(255)
  cin           String?  @db.VarChar(32)
  logoUri       String?  @map("logo_uri") @db.VarChar(512)
  registeredAddress String? @map("registered_address") @db.Text
  corporateAddress  String? @map("corporate_address") @db.Text

  // Statutory information
  pan           String?  @db.VarChar(10)
  tan           String?  @db.VarChar(10)
  gstin         String?  @db.VarChar(15)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@map("company")
}

model CompanyDocument {
  id           String  @id @db.VarChar(26)
  name         String  @db.VarChar(255)          // user-given label
  fileName     String  @map("file_name") @db.VarChar(255)
  mimeType     String  @map("mime_type") @db.VarChar(128)
  fileSize     Int     @map("file_size")          // bytes
  storagePath  String  @map("storage_path") @db.VarChar(512) // relative path on disk
  sortOrder    Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@map("company_document")
}

model BusinessUnit {
  id                   String   @id @db.VarChar(26)
  name                 String   @db.VarChar(128)
  description          String?  @db.Text
  costCentre           String?  @map("cost_centre") @db.VarChar(32)
  buHeadUserId         String   @map("bu_head_user_id") @db.VarChar(26)
  // JSON defining approval thresholds by module and amount. See docs/modules/04-expense-management.md
  approvalThresholds   Json?    @map("approval_thresholds")
  status               String   @default("ACTIVE") @db.VarChar(16)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  buHead   User @relation("BUHead", fields: [buHeadUserId], references: [id])

  leads            Lead[]
  opportunities    Opportunity[]
  projects         Project[]
  expenseSheets    ExpenseSheet[]
  materialRequests MaterialRequest[]
  members          BusinessUnitMember[]
  travelPlans      TravelPlan[]

  @@index([name])
  @@map("business_unit")
}

model Role {
  id          String  @id @db.VarChar(26)
  name        String  @unique @db.VarChar(64)
  displayName String  @map("display_name") @db.VarChar(128)
  description String? @db.Text
  permissions Json?
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members         BusinessUnitMember[]
  userRoles       UserRole[]
  sharedPasswords PasswordEntry[]

  @@map("role")
}

model BusinessUnitMember {
  id             String @id @db.VarChar(26)
  businessUnitId String @map("business_unit_id") @db.VarChar(26)
  userId         String @map("user_id") @db.VarChar(26)
  roleId         String @map("role_id") @db.VarChar(26)

  createdAt DateTime @default(now()) @map("created_at")

  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id])
  user         User         @relation("BUMemberships", fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([businessUnitId, userId])
  @@index([userId])
  @@map("business_unit_member")
}

model User {
  id         String     @id @db.VarChar(26)
  externalId String     @unique @map("external_id") @db.VarChar(128) // Keycloak sub
  email      String     @unique @db.VarChar(255)
  fullName   String     @map("full_name") @db.VarChar(255)
  phone      String?    @db.VarChar(32)
  status     UserStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  employee             Employee?
  buHeadOf             BusinessUnit[] @relation("BUHead")
  buMemberships        BusinessUnitMember[] @relation("BUMemberships")
  userRoles            UserRole[]
  ownedOpportunities   Opportunity[]          @relation("OpportunityOwner")
  activities           Activity[]             @relation("ActivityUser")
  ledTravelPlans       TravelPlan[]           @relation("TravelLeader")
  travelMemberships    TravelPlanTraveller[]
  passwordEntries      PasswordEntry[]        @relation("PasswordOwner")

  @@map("user")
}

model UserRole {
  id     String @id @db.VarChar(26)
  userId String @map("user_id") @db.VarChar(26)
  roleId String @map("role_id") @db.VarChar(26)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Employee {
  id                String   @id @db.VarChar(26)
  userId            String   @unique @map("user_id") @db.VarChar(26)
  employeeCode      String   @unique @map("employee_code") @db.VarChar(32)
  designation       String?  @db.VarChar(128)
  grade             String?  @db.VarChar(16)
  qualifications    Json?    // [{ degree, institute, year }, ...]
  skills            Json?    // ["node", "angular", ...]
  cvUri             String?  @map("cv_uri") @db.VarChar(512)
  dateOfJoining     DateTime? @map("date_of_joining") @db.Date
  availability      String?  @db.VarChar(32) // AVAILABLE | ON_PROJECT | ON_LEAVE
  reportingManagerId String? @map("reporting_manager_id") @db.VarChar(26)

  // Sensitive - encrypted at column level in production
  panHash       String? @map("pan_hash") @db.VarChar(128)
  aadhaarHash   String? @map("aadhaar_hash") @db.VarChar(128)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@map("employee")
}

model StatutoryRegistration {
  id              String   @id @db.VarChar(26)
  name            String   @db.VarChar(128)       // e.g. "GST Registration", "PAN Card"
  registrationId  String   @map("registration_id") @db.VarChar(128)
  portalUrl       String?  @map("portal_url") @db.VarChar(512)
  login           String?  @db.VarChar(255)       // encrypted at rest in prod
  password        String?  @db.VarChar(255)       // encrypted at rest in prod
  mobile          String?  @db.VarChar(32)        // associated mobile
  email           String?  @db.VarChar(255)       // associated email

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@map("statutory_registration")
}

model AppConfig {
  id    String @id @db.VarChar(26)
  key   String @unique @db.VarChar(64)
  value String @db.Text

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model LookupList {
  id    String @id @db.VarChar(26)
  code  String @unique @db.VarChar(64)    // e.g. "account_type", "lead_source"
  name  String @db.VarChar(128)           // e.g. "Account Type", "Lead Source"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items LookupItem[]

  @@map("lookup_list")
}

model LookupItem {
  id         String  @id @db.VarChar(26)
  listId     String  @map("list_id") @db.VarChar(26)
  label      String  @db.VarChar(128)     // display text
  value      String  @db.VarChar(64)      // stored value
  sortOrder  Int     @default(0) @map("sort_order")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  list LookupList @relation(fields: [listId], references: [id])

  @@unique([listId, value])
  @@index([listId, sortOrder])
  @@map("lookup_item")
}

model Government {
  id             String         @id @db.VarChar(26)
  code           String         @unique @db.VarChar(5)
  name           String         @db.VarChar(255)
  governmentType GovernmentType @map("government_type")
  country        String         @db.VarChar(128)       // e.g. "India"
  capital        String?        @db.VarChar(128)
  notes          String?        @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  influencers Influencer[]
  accounts    Account[]

  @@index([governmentType])
  @@index([country])
  @@map("government")
}

model Certification {
  id             String   @id @db.VarChar(26)
  name           String   @db.VarChar(128)
  scope          String?  @db.Text
  certificateNo  String?  @map("certificate_no") @db.VarChar(64)
  issuingBody    String?  @map("issuing_body") @db.VarChar(128)
  validityStart  DateTime? @map("validity_start") @db.Date
  validityEnd    DateTime? @map("validity_end") @db.Date
  certificateUri String?  @map("certificate_uri") @db.VarChar(512)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@index([validityEnd])
  @@map("certification")
}

model Dsc {
  id            String    @id @db.VarChar(26)
  holderUserId  String    @map("holder_user_id") @db.VarChar(26)
  serialNo      String    @unique @map("serial_no") @db.VarChar(128)
  issuer        String?   @db.VarChar(128)
  validityStart DateTime? @map("validity_start") @db.Date
  validityEnd   DateTime? @map("validity_end") @db.Date
  status        String    @default("ACTIVE") @db.VarChar(16) // ACTIVE | EXPIRED | REVOKED

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@index([validityEnd])
  @@map("dsc")
}

model Empanelment {
  id               String   @id @db.VarChar(26)
  agencyName       String   @map("agency_name") @db.VarChar(255)
  category         String?  @db.VarChar(128)
  empanelmentNo    String?  @map("empanelment_no") @db.VarChar(64)
  rateContractRef  String?  @map("rate_contract_ref") @db.VarChar(128)
  validityStart    DateTime? @map("validity_start") @db.Date
  validityEnd      DateTime? @map("validity_end") @db.Date
  certificateUri   String?  @map("certificate_uri") @db.VarChar(512)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@index([validityEnd])
  @@map("empanelment")
}

model TurnoverRecord {
  id              String   @id @db.VarChar(26)
  financialYear   String   @map("financial_year") @db.VarChar(10) // "2024-25"
  revenuePaise    BigInt   @map("revenue_paise")
  netWorthPaise   BigInt?  @map("net_worth_paise")
  auditorName     String?  @map("auditor_name") @db.VarChar(255)
  auditedFlag     Boolean  @default(false) @map("audited_flag")
  certificateUri  String?  @map("certificate_uri") @db.VarChar(512)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@unique([financialYear])
  @@map("turnover_record")
}

model PastProject {
  id                    String   @id @db.VarChar(26)
  title                 String   @db.VarChar(255)
  clientName            String   @map("client_name") @db.VarChar(255)
  orderValuePaise       BigInt   @map("order_value_paise")
  startDate             DateTime? @map("start_date") @db.Date
  completionDate        DateTime? @map("completion_date") @db.Date
  completionPct         Int      @default(0) @map("completion_pct")
  completionCertUri     String?  @map("completion_cert_uri") @db.VarChar(512)
  domain                String?  @db.VarChar(128)
  keywords              Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@map("past_project")
}

model BankAccount {
  id          String  @id @db.VarChar(26)
  bankName    String  @map("bank_name") @db.VarChar(128)
  accountName String  @map("account_name") @db.VarChar(255)
  accountNo   String  @map("account_no") @db.VarChar(64) // encrypted in prod
  ifsc        String  @db.VarChar(16)
  branch      String? @db.VarChar(255)
  purpose     String  @db.VarChar(32) // EMD | RECEIVABLES | PAYROLL | GENERAL

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  @@map("bank_account")
}

// ==========================================================================
// Module 2 — Sales (stub; fill in per docs/modules/02-sales.md)
// ==========================================================================

model Account {
  id               String      @id @db.VarChar(26)
  code             String      @unique @db.VarChar(5)
  name             String      @db.VarChar(255)
  shortName        String?     @map("short_name") @db.VarChar(64)
  accountType      String      @map("account_type") @db.VarChar(64)
  parentAccountId  String?     @map("parent_account_id") @db.VarChar(26)
  website          String?     @db.VarChar(512)
  phone            String?     @db.VarChar(32)
  email            String?     @db.VarChar(255)
  address          String?     @db.Text
  city             String?     @db.VarChar(128)
  state            String?     @db.VarChar(64)
  pincode          String?     @db.VarChar(10)
  gstin            String?     @db.VarChar(15)
  notes            String?     @db.Text
  ownerUserId      String?     @map("owner_user_id") @db.VarChar(26)
  governmentId     String?     @map("government_id") @db.VarChar(26)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  parentAccount   Account?         @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts   Account[]        @relation("AccountHierarchy")
  government      Government?      @relation(fields: [governmentId], references: [id])
  accountContacts        AccountContact[]
  leads                  Lead[]
  opportunities          Opportunity[] @relation("OpportunityAccount")
  endClientOpportunities Opportunity[] @relation("OpportunityEndClient")

  @@index([name])
  @@index([accountType])
  @@map("account")
}

model Contact {
  id              String          @id @db.VarChar(26)
  firstName       String          @map("first_name") @db.VarChar(128)
  lastName        String?         @map("last_name") @db.VarChar(128)
  designation     String?         @db.VarChar(128)
  department      String?         @db.VarChar(255)
  email           String?         @db.VarChar(255)
  phone           String?         @db.VarChar(32)
  mobile          String?         @db.VarChar(32)
  influenceLevel  InfluenceLevel? @map("influence_level")
  notes           String?         @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  accountContacts     AccountContact[]
  leads               Lead[]               @relation("LeadContact")
  opportunityContacts OpportunityContact[]
  activityContacts    ActivityContact[]

  @@index([lastName, firstName])
  @@map("contact")
}

model AccountContact {
  id        String @id @db.VarChar(26)
  accountId String @map("account_id") @db.VarChar(26)
  contactId String @map("contact_id") @db.VarChar(26)

  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([accountId, contactId])
  @@index([contactId])
  @@map("account_contact")
}

model Influencer {
  id               String         @id @db.VarChar(26)
  name             String         @db.VarChar(255)
  influencerType   InfluencerType @map("influencer_type")
  governmentId     String         @map("government_id") @db.VarChar(26)
  partyName        String?        @map("party_name") @db.VarChar(128)
  qualifier        String?        @db.VarChar(255)
  phone            String?        @db.VarChar(32)
  email            String?        @db.VarChar(255)
  influenceLevel   InfluenceLevel? @map("influence_level")
  rating           Int?           @db.TinyInt                             // 1–5 stars
  notes            String?        @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  government              Government              @relation(fields: [governmentId], references: [id])
  opportunityInfluencers   OpportunityInfluencer[]

  @@index([governmentId])
  @@index([influencerType])
  @@map("influencer")
}

model OpportunityInfluencer {
  id             String @id @db.VarChar(26)
  opportunityId  String @map("opportunity_id") @db.VarChar(26)
  influencerId   String @map("influencer_id") @db.VarChar(26)

  createdAt DateTime @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])
  influencer  Influencer  @relation(fields: [influencerId], references: [id])

  @@unique([opportunityId, influencerId])
  @@index([influencerId])
  @@map("opportunity_influencer")
}

model OpportunityContact {
  id            String @id @db.VarChar(26)
  opportunityId String @map("opportunity_id") @db.VarChar(26)
  contactId     String @map("contact_id") @db.VarChar(26)

  createdAt DateTime @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])
  contact     Contact     @relation(fields: [contactId], references: [id])

  @@unique([opportunityId, contactId])
  @@index([contactId])
  @@map("opportunity_contact")
}

model Lead {
  id                    String     @id @db.VarChar(26)
  title                 String     @db.VarChar(255)
  accountId             String?    @map("account_id") @db.VarChar(26)
  contactId             String?    @map("contact_id") @db.VarChar(26)
  businessUnitId        String?    @map("business_unit_id") @db.VarChar(26)
  source                LeadSource
  status                LeadStatus @default(NEW)
  description           String?    @db.Text
  estimatedValuePaise   BigInt?    @map("estimated_value_paise")
  expectedClosureDate   DateTime?  @map("expected_closure_date") @db.Date
  ownerUserId           String?    @map("owner_user_id") @db.VarChar(26)
  convertedOpportunityId String?   @map("converted_opportunity_id") @db.VarChar(26)
  lostReason            String?    @map("lost_reason") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.VarChar(26)
  updatedBy String    @map("updated_by") @db.VarChar(26)

  account              Account?      @relation(fields: [accountId], references: [id])
  contact              Contact?      @relation("LeadContact", fields: [contactId], references: [id])
  businessUnit         BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  convertedOpportunity Opportunity?  @relation("ConvertedFromLead", fields: [convertedOpportunityId], references: [id])

  @@index([status])
  @@index([accountId])
  @@index([businessUnitId, status])
  @@map("lead")
}

model Opportunity {
  id                 String            @id @db.VarChar(26)
  businessUnitId     String            @map("business_unit_id") @db.VarChar(26)
