    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jose": "^5.4.0",
    "multer": "^2.1.1",
    "pino": "^9.1.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
