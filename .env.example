# ==================================================================
# GovProjects Platform — Environment Variables (example)
# Copy to .env and fill in. Never commit the real .env.
# ==================================================================

# ---------- App ----------
NODE_ENV=development
APP_NAME=govprojects-platform
APP_VERSION=0.0.1
LOG_LEVEL=debug

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=3000
API_BASE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3000/api/v1

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200,http://localhost:8100

# ---------- Web ----------
WEB_PORT=4200
WEB_BASE_URL=http://localhost:4200

# ---------- MySQL ----------
DATABASE_URL=mysql://govprojects:govprojects@localhost:3306/govprojects
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=govprojects
MYSQL_USER=govprojects
MYSQL_PASSWORD=govprojects

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---------- RabbitMQ ----------
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=govprojects.events

# ---------- OpenSearch ----------
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ---------- Object Storage (S3-compatible; MinIO in local dev) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=govprojects
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---------- Keycloak (Auth) ----------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=govprojects
KEYCLOAK_CLIENT_ID=govprojects-api
KEYCLOAK_CLIENT_SECRET=replace-me
KEYCLOAK_WEB_CLIENT_ID=govprojects-web
KEYCLOAK_ISSUER=http://localhost:8080/realms/govprojects

# ---------- Workflow (Camunda 8 / Zeebe) ----------
ZEEBE_ADDRESS=localhost:26500
ZEEBE_CLIENT_ID=
ZEEBE_CLIENT_SECRET=

# ---------- Email ----------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@govprojects.local

# ---------- SMS / WhatsApp (India — MSG91 / Gupshup) ----------
MSG91_AUTH_KEY=
MSG91_SENDER=GOVPRJ
GUPSHUP_API_KEY=

# ---------- Observability ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# ---------- Security ----------
JWT_ISSUER=http://localhost:8080/realms/govprojects
JWT_AUDIENCE=govprojects-api
ENCRYPTION_KEY_ID=local-dev-key

# ---------- Feature flags ----------
FEATURE_MANAGED_TENDERS=true
FEATURE_MOBILE_OCR=false
FEATURE_ACCOUNTING_INTEGRATION=false

# ---------- Misc ----------
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
